# ==========================================
# AUTOMATED BLOG GENERATION - API KEYS
# ==========================================
# IMPORTANT: Never commit .env.local to git!

# Anthropic Claude API (for content generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini API (for image generation)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Unsplash Access Key (optional fallback for images)
# Get your key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# Auto-commit setting (set to false for safety - manual review required)
AUTO_COMMIT=false

# ==========================================
# ZAPIER WEBHOOKS
# ==========================================
# Partner inquiry webhook (used by /api/partners/inquiry)
ZAPIER_PARTNER_INQUIRY_WEBHOOK_URL=your-zapier-webhook-url-here

# Fallback webhook URL for general use
ZAPIER_WEBHOOK_URL=your-zapier-webhook-url-here

# Client-side accessible webhook URL (for corporate page form)
# REQUIRED: Must have NEXT_PUBLIC_ prefix to be accessible in browser
NEXT_PUBLIC_ZAPIER_PARTNER_WEBHOOK_URL=your-zapier-webhook-url-here

# ==========================================
# SHOPIFY CONFIGURATION
# ==========================================
# Storefront API (public)
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# Admin API (server-side only)
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ==========================================
# DATABASE (VERCEL POSTGRES)
# ==========================================
POSTGRES_URL=your-postgres-connection-string
POSTGRES_URL_NON_POOLING=your-postgres-direct-url

# ==========================================
# STRIPE (PAYMENTS)
# ==========================================
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ==========================================
# ADMIN API
# ==========================================
# Secure key for admin sync endpoints
ADMIN_API_KEY=your-secure-admin-api-key

# ==========================================
# AUTHENTICATION
# ==========================================
# Secret for JWT session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# ==========================================
# AI SERVICES (CLAUDE)
# ==========================================
# For AI-powered inventory features
OPENROUTER_API_KEY=your-openrouter-key
