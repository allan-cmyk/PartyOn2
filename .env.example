# ==========================================
# GOOGLE ANALYTICS 4 (GA4)
# ==========================================
# GA4 Measurement ID for tracking
# Get from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==========================================
# AUTOMATED BLOG GENERATION - API KEYS
# ==========================================
# IMPORTANT: Never commit .env.local to git!

# Anthropic Claude API (for content generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google Gemini API (for image generation)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Unsplash Access Key (optional fallback for images)
# Get your key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# Auto-commit setting (set to false for safety - manual review required)
AUTO_COMMIT=false

# ==========================================
# ZAPIER WEBHOOKS
# ==========================================
# Partner inquiry webhook (used by /api/partners/inquiry)
ZAPIER_PARTNER_INQUIRY_WEBHOOK_URL=your-zapier-webhook-url-here

# Fallback webhook URL for general use
ZAPIER_WEBHOOK_URL=your-zapier-webhook-url-here

# Client-side accessible webhook URL (for corporate page form)
# REQUIRED: Must have NEXT_PUBLIC_ prefix to be accessible in browser
NEXT_PUBLIC_ZAPIER_PARTNER_WEBHOOK_URL=your-zapier-webhook-url-here

# ==========================================
# SHOPIFY CONFIGURATION
# ==========================================
# Storefront API (public)
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token

# Admin API (server-side only)
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ==========================================
# DATABASE (VERCEL POSTGRES)
# ==========================================
POSTGRES_URL=your-postgres-connection-string
POSTGRES_URL_NON_POOLING=your-postgres-direct-url

# ==========================================
# STRIPE (PAYMENTS)
# ==========================================
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ==========================================
# ADMIN API
# ==========================================
# Secure key for admin sync endpoints
ADMIN_API_KEY=your-secure-admin-api-key

# ==========================================
# AUTHENTICATION
# ==========================================
# Secret for JWT session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# ==========================================
# AI SERVICES (CLAUDE)
# ==========================================
# For AI-powered inventory features
OPENROUTER_API_KEY=your-openrouter-key

# ==========================================
# VERCEL ANALYTICS DRAIN
# ==========================================
# Signature verification secret for Vercel Analytics Drain
# Get from: Vercel Dashboard > Project > Settings > Drains > Edit Drain
# Leave empty to disable signature verification (not recommended for production)
VERCEL_DRAIN_SECRET=your-vercel-drain-secret

# ==========================================
# APP URL
# ==========================================
# Public base URL used in emails, checkout redirects, share links.
NEXT_PUBLIC_APP_URL=https://partyondelivery.com
# Alt name used by legacy group-orders v1 code paths
NEXT_PUBLIC_BASE_URL=https://partyondelivery.com

# ==========================================
# CRON JOBS
# ==========================================
# Bearer token required by /api/cron/* endpoints (generate-blog, reconcile-orders, affiliate-*, group-orders-v2)
CRON_SECRET=your-cron-secret

# ==========================================
# EMAIL (RESEND)
# ==========================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=orders@partyondelivery.com
# Signing secret for /api/webhooks/resend delivery/bounce events
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret

# ==========================================
# SMS / CRM (GOHIGHLEVEL)
# ==========================================
# Order confirmations/SMS webhook
GHL_ORDER_WEBHOOK_URL=your-ghl-order-webhook
# Post-delivery review request webhook
GHL_REVIEW_WEBHOOK_URL=your-ghl-review-webhook
# Dashboard-share SMS webhook
GHL_DASHBOARD_WEBHOOK_URL=your-ghl-dashboard-webhook
# Used by /api/v2/group-orders/[code]/send-link
GHL_WEBHOOK_URL=your-ghl-webhook

# ==========================================
# META / FACEBOOK PIXEL
# ==========================================
# Falls back to a baked-in ID if unset — set this to override.
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id

# ==========================================
# SUPABASE (product image storage)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==========================================
# VERCEL BLOB
# ==========================================
# Read/write token for uploads (product images, PDFs)
BLOB_READ_WRITE_TOKEN=your-blob-token

# ==========================================
# GOOGLE — ANALYTICS 4 DATA API & SEARCH CONSOLE
# ==========================================
GOOGLE_GA4_PROPERTY_ID=your-ga4-property-id
GA4_PROPERTY_ID=your-ga4-property-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your-google-private-key
GOOGLE_SEARCH_CONSOLE_SITE=sc-domain:partyondelivery.com
# JSON blob fallback used by ga4-behavior
GOOGLE_APPLICATION_CREDENTIALS_JSON=your-google-credentials-json

# ==========================================
# GOOGLE CALENDAR (ops scheduling)
# ==========================================
GOOGLE_CALENDAR_SERVICE_ACCOUNT_EMAIL=your-calendar-service-account
GOOGLE_CALENDAR_SERVICE_ACCOUNT_KEY=your-calendar-private-key
GOOGLE_CALENDAR_ID=your-calendar-id

# ==========================================
# ADMIN / EMPLOYEE LOGIN
# ==========================================
ADMIN_PASSWORD=your-admin-password
EMPLOYEE_PASSWORD=your-employee-password

# ==========================================
# AUTH — SESSION SECRET ALIAS
# ==========================================
# Fallback used when JWT_SECRET is unset
NEXTAUTH_SECRET=your-nextauth-secret

# ==========================================
# MCP (Model Context Protocol) — ops AI tooling
# ==========================================
MCP_AUTH_TOKEN_READ=your-mcp-read-token
MCP_AUTH_TOKEN_WRITE=your-mcp-write-token
# Optional previous-token values for rotation
MCP_AUTH_TOKEN_READ_PREV=
MCP_AUTH_TOKEN_WRITE_PREV=

# ==========================================
# PREMIER BOAT — GOOGLE SHEET IMPORT
# ==========================================
PREMIER_SCHEDULE_PUBLIC_KEY=your-schedule-public-key
PREMIER_SHEET_SERVICE_ACCOUNT_EMAIL=your-sheet-service-account
PREMIER_SHEET_SERVICE_ACCOUNT_KEY=your-sheet-private-key
PREMIER_SHEET_ID=your-sheet-id
# Used by /api/ops/boat-schedule/sync
BOAT_SCHEDULE_SYNC_KEY=your-sync-key

# ==========================================
# ZAPIER — CONTACT FORM
# ==========================================
ZAPIER_CONTACT_WEBHOOK_URL=your-contact-webhook-url

# ==========================================
# VERCEL KV (optional cache)
# ==========================================
KV_URL=your-kv-url

# ==========================================
# ALTERNATE SHOPIFY ADMIN TOKEN NAME
# ==========================================
# Some code paths still read the older var name — set this OR SHOPIFY_ADMIN_ACCESS_TOKEN above
SHOPIFY_ADMIN_API_TOKEN=your-admin-token
