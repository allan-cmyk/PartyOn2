  id              String             @id @default(uuid())
  name            String
  hostCustomerId  String?            @map("host_customer_id")
  hostName        String             @map("host_name")
  hostEmail       String?            @map("host_email")
  hostPhone       String?            @map("host_phone")
  shareCode       String             @unique @map("share_code")
  status          GroupOrderV2Status @default(ACTIVE)
  expiresAt       DateTime           @map("expires_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tabs         SubOrder[]
  participants GroupParticipantV2[]

  hostCustomer Customer? @relation("GroupOrderV2Host", fields: [hostCustomerId], references: [id], onDelete: SetNull)

  @@index([shareCode])
  @@index([hostCustomerId])
  @@index([status])
  @@map("group_orders_v2")
}

model SubOrder {
  id             String         @id @default(uuid())
  groupOrderId   String         @map("group_order_id")
  name           String
  position       Int            @default(0)
  deliveryDate   DateTime       @map("delivery_date")
  deliveryTime   String         @map("delivery_time")
  deliveryAddress Json          @map("delivery_address")
  deliveryPhone  String?        @map("delivery_phone")
  deliveryNotes  String?        @map("delivery_notes") @db.Text
  orderDeadline  DateTime       @map("order_deadline")
  deliveryFee    Decimal        @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  deliveryFeeWaived Boolean     @default(false) @map("delivery_fee_waived")
  orderType      String?        @map("order_type")
  status         SubOrderStatus @default(OPEN)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  groupOrder      GroupOrderV2         @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
  draftItems      DraftCartItem[]
  purchasedItems  PurchasedItem[]
  payments        ParticipantPayment[]
  deliveryInvoice GroupDeliveryInvoice?

  @@index([groupOrderId])
  @@index([orderDeadline])
  @@index([status])
  @@map("sub_orders")
}

model GroupParticipantV2 {
  id             String                  @id @default(uuid())
  groupOrderId   String                  @map("group_order_id")
  customerId     String?                 @map("customer_id")
  guestName      String?                 @map("guest_name")
  guestEmail     String?                 @map("guest_email")
  ageVerified    Boolean                 @default(false) @map("age_verified")
  isHost         Boolean                 @default(false) @map("is_host")
  status         GroupV2ParticipantStatus @default(ACTIVE)
  joinedAt       DateTime                @default(now()) @map("joined_at")

  groupOrder     GroupOrderV2       @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
  customer       Customer?          @relation("CustomerParticipationsV2", fields: [customerId], references: [id], onDelete: SetNull)
  draftItems     DraftCartItem[]
  purchasedItems PurchasedItem[]
  payments       ParticipantPayment[]

  @@unique([groupOrderId, customerId])
  @@unique([groupOrderId, guestEmail])
  @@index([groupOrderId])
  @@index([status])
  @@map("group_participants_v2")
}

model DraftCartItem {
  id                   String   @id @default(uuid())
  subOrderId           String   @map("sub_order_id")
  addedByParticipantId String   @map("added_by_participant_id")
  productId            String   @map("product_id")
  variantId            String   @map("variant_id")
  title                String
  variantTitle         String?  @map("variant_title")
  price                Decimal  @db.Decimal(10, 2)
  imageUrl             String?  @map("image_url")
  quantity             Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subOrder    SubOrder           @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  addedBy     GroupParticipantV2 @relation(fields: [addedByParticipantId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id])
  variant     ProductVariant     @relation(fields: [variantId], references: [id])

  @@unique([subOrderId, addedByParticipantId, variantId])
  @@index([subOrderId])
  @@index([addedByParticipantId])
  @@map("draft_cart_items")
}

model PurchasedItem {
  id            String   @id @default(uuid())
  subOrderId    String   @map("sub_order_id")
  participantId String   @map("participant_id")
  paymentId     String   @map("payment_id")
  productId     String   @map("product_id")
  variantId     String   @map("variant_id")
  title         String
  variantTitle  String?  @map("variant_title")
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?  @map("image_url")
  quantity      Int

  createdAt DateTime @default(now()) @map("created_at")

  subOrder    SubOrder           @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  participant GroupParticipantV2 @relation(fields: [participantId], references: [id], onDelete: Cascade)
  payment     ParticipantPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  product     Product            @relation(fields: [productId], references: [id])
  variant     ProductVariant     @relation(fields: [variantId], references: [id])

  @@index([subOrderId])
  @@index([participantId])
  @@index([paymentId])
  @@map("purchased_items")
}

model ParticipantPayment {
  id                      String               @id @default(uuid())
  subOrderId              String               @map("sub_order_id")
  participantId           String               @map("participant_id")
  stripeCheckoutSessionId String?              @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?              @unique @map("stripe_payment_intent_id")
  subtotal                Decimal              @default(0) @db.Decimal(10, 2)
  taxAmount               Decimal              @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discountCode            String?              @map("discount_code")
  discountAmount          Decimal              @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total                   Decimal              @default(0) @db.Decimal(10, 2)
  status                  GroupV2PaymentStatus @default(PENDING)
  paidAt                  DateTime?            @map("paid_at")
  orderId                 String?              @map("order_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  subOrder       SubOrder           @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  participant    GroupParticipantV2 @relation(fields: [participantId], references: [id], onDelete: Cascade)
  purchasedItems PurchasedItem[]

  @@index([subOrderId])
  @@index([participantId])
  @@index([status])
  @@map("participant_payments")
}

// ==========================================
// EMAIL TEMPLATE CONTENT (ADMIN TEXT OVERRIDES)
// ==========================================

model EmailTemplateContent {
  id           String   @id @default(uuid())
  templateType String   @unique @map("template_type")
  content      Json
  updatedBy    String?  @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_template_content")
}

// ==========================================
// INVENTORY NOTES (Quick adjustment instructions)
// ==========================================

model InventoryNote {
  id           String   @id @default(cuid())
  content      String   @db.Text
  status       String   @default("pending") // pending, processed, dismissed
  parsedResult Json?    @map("parsed_result")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("inventory_notes")
}

model GroupDeliveryInvoice {
  id                      String               @id @default(uuid())
  subOrderId              String               @unique @map("sub_order_id")
  hostParticipantId       String               @map("host_participant_id")
  deliveryFee             Decimal              @db.Decimal(10, 2)
  discountCode            String?              @map("discount_code")
  discountAmount          Decimal              @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total                   Decimal              @db.Decimal(10, 2)
  stripeCheckoutSessionId String?              @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?              @unique @map("stripe_payment_intent_id")
  status                  GroupV2PaymentStatus @default(PENDING)
  paidAt                  DateTime?            @map("paid_at")
  sentAt                  DateTime?            @map("sent_at")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  subOrder SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("group_delivery_invoices")
}

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  status        String   // RECEIVED, PROCESSED, FAILED
  errorMessage  String?  @map("error_message") @db.Text
  processingMs  Int?     @map("processing_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
}

// ==========================================
// AFFILIATE / PARTNER PROGRAM
// ==========================================

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AffiliateStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum AffiliateCategory {
  BARTENDER
  BOAT
  VENUE
  PLANNER
  OTHER
}

enum CommissionStatus {
  HELD
  HELD_REVIEW
  APPROVED
  VOID
  PAID
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

model PartnerApplication {
  id              String            @id @default(uuid())
  contactName     String            @map("contact_name")
  businessName    String            @map("business_name")
  email           String
  phone           String?
  category        AffiliateCategory
  websiteOrSocial String?           @map("website_or_social")
  serviceArea     String?           @map("service_area")
  notes           String?           @db.Text
  consent         Boolean
  status          ApplicationStatus @default(PENDING)
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewedBy      String?           @map("reviewed_by")
  affiliateId     String?           @map("affiliate_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])

  @@index([email])
  @@index([status])
  @@map("partner_applications")
}

model Affiliate {
  id            String            @id @default(uuid())
  code          String            @unique
  status        AffiliateStatus   @default(ACTIVE)
  category      AffiliateCategory
  contactName   String            @map("contact_name")
  businessName  String            @map("business_name")
  email         String            @unique
  phone         String?

  commissionRateOverride Decimal? @map("commission_rate_override") @db.Decimal(5, 4)
  categoryRateOverride   Decimal? @map("category_rate_override") @db.Decimal(5, 4)
  customerPerk           String   @default("Free Delivery") @map("customer_perk")

  payoutMethod  String? @map("payout_method")
  payoutDetails Json?   @map("payout_details")

  internalNotes String? @map("internal_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applications PartnerApplication[]
  commissions  AffiliateCommission[]
  payouts      AffiliatePayout[]
  orders       Order[]              @relation("AffiliateOrders")
  magicLinks   MagicLinkToken[]

  @@index([code])
  @@map("affiliates")
}

model AffiliateCommission {
  id                   String           @id @default(uuid())
  affiliateId          String           @map("affiliate_id")
  orderId              String           @map("order_id")
  commissionBaseCents  Int              @map("commission_base_cents")
  commissionRate       Decimal          @map("commission_rate") @db.Decimal(5, 4)
  commissionAmountCents Int             @map("commission_amount_cents")
  tierAtTime           String           @map("tier_at_time")
  status               CommissionStatus @default(HELD)
  isSelfReferral       Boolean          @default(false) @map("is_self_referral")
  deliveredAt          DateTime?        @map("delivered_at")
  holdUntil            DateTime?        @map("hold_until")
  voidedAt             DateTime?        @map("voided_at")
  voidedReason         String?          @map("voided_reason")
  payoutId             String?          @map("payout_id")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  affiliate Affiliate       @relation(fields: [affiliateId], references: [id])
  order     Order           @relation(fields: [orderId], references: [id])
  payout    AffiliatePayout? @relation(fields: [payoutId], references: [id])

  @@index([affiliateId])
  @@index([orderId])
  @@index([status])
  @@index([payoutId])
  @@map("affiliate_commissions")
}

model AffiliatePayout {
  id              String       @id @default(uuid())
  affiliateId     String       @map("affiliate_id")
  payoutPeriod    String       @map("payout_period")
  totalAmountCents Int         @map("total_amount_cents")
  status          PayoutStatus @default(PENDING)
  processedAt     DateTime?    @map("processed_at")
  notes           String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  affiliate  Affiliate           @relation(fields: [affiliateId], references: [id])
  commissions AffiliateCommission[]
  lineItems  PayoutLineItem[]

  @@index([affiliateId])
  @@index([payoutPeriod])
  @@index([status])
  @@map("affiliate_payouts")
}

model PayoutLineItem {
  id           String @id @default(uuid())
  payoutId     String @map("payout_id")
  commissionId String @map("commission_id")
  amountCents  Int    @map("amount_cents")
  createdAt    DateTime @default(now()) @map("created_at")

  payout AffiliatePayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@index([payoutId])
  @@map("payout_line_items")
}

model MagicLinkToken {
  id          String    @id @default(uuid())
  affiliateId String    @map("affiliate_id")
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([token])
  @@index([affiliateId])
  @@map("magic_link_tokens")
}
