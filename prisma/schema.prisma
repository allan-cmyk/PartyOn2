// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Partner Inquiries from the partner pages
model PartnerInquiry {
  id              String   @id @default(uuid())
  businessName    String   @map("business_name")
  businessType    String?  @map("business_type")
  contactName     String   @map("contact_name")
  email           String
  phone           String?
  numberOfRooms   String?  @map("number_of_rooms")
  monthlyVolume   String?  @map("monthly_volume")
  currentProvider String?  @map("current_provider")
  interests       String[]
  message         String?
  status          String   @default("new")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("partner_inquiries")
}

// Analytics Snapshots - daily analytics data
model AnalyticsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date
  sessions           Int      @default(0)
  users              Int      @default(0)
  pageviews          Int      @default(0)
  bounceRate         Decimal? @map("bounce_rate")
  avgSessionDuration Decimal? @map("avg_session_duration")
  organicSessions    Int      @default(0) @map("organic_sessions")
  directSessions     Int      @default(0) @map("direct_sessions")
  referralSessions   Int      @default(0) @map("referral_sessions")
  socialSessions     Int      @default(0) @map("social_sessions")
  paidSessions       Int      @default(0) @map("paid_sessions")
  orders             Int      @default(0)
  revenue            Decimal  @default(0)
  averageOrderValue  Decimal  @default(0) @map("average_order_value")
  impressions        Int      @default(0)
  clicks             Int      @default(0)
  ctr                Decimal? @map("ctr")
  avgPosition        Decimal? @map("avg_position")
  topPages           Json?    @map("top_pages")
  topProducts        Json?    @map("top_products")
  topKeywords        Json?    @map("top_keywords")
  topReferrers       Json?    @map("top_referrers")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@map("analytics_snapshots")
}

// A/B Testing Experiments
model Experiment {
  id             String           @id @default(uuid())
  name           String
  description    String?
  page           String
  elementId      String           @map("element_id")
  status         ExperimentStatus @default(DRAFT)
  startDate      DateTime?        @map("start_date")
  endDate        DateTime?        @map("end_date")
  goalMetric     String           @map("goal_metric")
  goalValue      String?          @map("goal_value")
  winningVariant String?          @map("winning_variant")
  confidence     Float?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  variants ExperimentVariant[]

  @@map("experiments")
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

// Experiment Variants for A/B testing
model ExperimentVariant {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  name         String
  description  String?
  isControl    Boolean  @default(false) @map("is_control")
  weight       Int      @default(50)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  revenue      Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@map("variants")
}

// Group Order Items - items added by participants
model GroupOrderItem {
  id             String   @id @default(uuid())
  groupOrderId   String   @map("group_order_id")
  participantId  String   @map("participant_id")
  shopifyLineId  String   @map("shopify_line_id")
  title          String
  variantTitle   String?  @map("variant_title")
  quantity       Int
  price          Decimal
  imageUrl       String?  @map("image_url")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([groupOrderId])
  @@index([participantId])
  @@map("group_order_items")
}

// Group Orders - for group ordering feature
model GroupOrder {
  id                 String           @id @default(uuid())
  name               String
  hostCustomerId     String?          @map("host_customer_id")
  hostName           String?          @map("host_name")
  shareCode          String           @unique @map("share_code")
  status             GroupOrderStatus @default(ACTIVE)
  deliveryDate       DateTime         @map("delivery_date")
  deliveryTime       String           @map("delivery_time")
  deliveryAddress    Json             @map("delivery_address")
  minimumOrderAmount Decimal          @default(100.00) @map("minimum_order_amount")
  expiresAt          DateTime         @map("expires_at")

  // Payment deadline for multi-payment system
  multiPaymentEnabled   Boolean       @default(false) @map("multi_payment_enabled")
  paymentDeadline       DateTime?     @map("payment_deadline")
  paymentReminderSentAt DateTime?     @map("payment_reminder_sent_at")

  // Host decision for partial payments
  hostDecision          HostDecision? @map("host_decision")
  hostDecisionAt        DateTime?     @map("host_decision_at")

  // Aggregated payment tracking
  totalPaid             Decimal       @default(0) @map("total_paid") @db.Decimal(10, 2)
  totalExpected         Decimal       @default(0) @map("total_expected") @db.Decimal(10, 2)

  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  participants   GroupParticipant[]
  payments       GroupOrderPayment[]
  orderAnalytics OrderAnalytics[]

  // New relations for inventory management system
  hostCustomer Customer? @relation("GroupOrderHost", fields: [hostCustomerId], references: [id], onDelete: SetNull, map: "group_orders_host_customer_fkey")
  carts        Cart[]
  orders       Order[]

  @@index([shareCode])
  @@index([hostCustomerId])
  @@map("group_orders")
}

// Participants in group orders
model GroupParticipant {
  id           String            @id @default(uuid())
  groupOrderId String            @map("group_order_id")
  customerId   String?           @map("customer_id")
  guestName    String?           @map("guest_name")
  guestEmail   String?           @map("guest_email")
  cartId       String            @map("cart_id")
  ageVerified  Boolean           @default(false) @map("age_verified")
  status       ParticipantStatus @default(ACTIVE)
  cartTotal    Decimal           @default(0) @map("cart_total")
  itemCount    Int               @default(0) @map("item_count")
  joinedAt     DateTime          @default(now()) @map("joined_at")

  // Checkout tracking (existing columns in production DB)
  checkedOutAt    DateTime? @map("checked_out_at")
  shopifyOrderId  String?   @map("shopify_order_id")
  shopifyOrderName String?  @map("shopify_order_name")

  groupOrder GroupOrder @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation("CustomerParticipations", fields: [customerId], references: [id], onDelete: SetNull)
  payment    GroupOrderPayment?

  @@unique([groupOrderId, cartId])
  @@index([groupOrderId])
  @@index([cartId])
  @@map("group_participants")
}

// Payment tracking for multi-payment group orders
model GroupOrderPayment {
  id                      String        @id @default(uuid())
  groupOrderId            String        @map("group_order_id")
  participantId           String        @unique @map("participant_id")

  // Stripe payment tracking
  stripeCheckoutSessionId String?       @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?       @unique @map("stripe_payment_intent_id")

  // Amount breakdown
  subtotal                Decimal       @db.Decimal(10, 2)
  taxAmount               Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  deliveryContribution    Decimal       @default(0) @map("delivery_contribution") @db.Decimal(10, 2)
  total                   Decimal       @db.Decimal(10, 2)

  // Payment status
  status                  PaymentStatus @default(PENDING)
  paidAt                  DateTime?     @map("paid_at")
  expiresAt               DateTime?     @map("expires_at")

  // Refund tracking
  refundedAmount          Decimal       @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  refundedAt              DateTime?     @map("refunded_at")

  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  groupOrder  GroupOrder       @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
  participant GroupParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([groupOrderId])
  @@index([status])
  @@map("group_order_payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  EXPIRED
  CANCELLED
}

enum HostDecision {
  PROCEED_PARTIAL      // Ship for those who paid
  CANCEL_REFUND_ALL    // Cancel entire order, refund everyone
  EXTEND_DEADLINE      // Give more time for remaining payments
}

// Order Analytics - supplementary data for Shopify orders
model OrderAnalytics {
  id              String      @id @default(uuid())
  shopifyOrderId  String?     @unique @map("shopify_order_id")
  customerId      String      @map("customer_id")
  orderTotal      Decimal     @map("order_total")
  deliveryDate    DateTime?   @map("delivery_date")
  deliveryTime    String?     @map("delivery_time")
  deliveryAddress Json?       @map("delivery_address")
  orderSource     OrderSource @map("order_source")
  partnerId       String?     @map("partner_id")
  groupOrderId    String?     @map("group_order_id")
  createdAt       DateTime    @default(now()) @map("created_at")

  groupOrder GroupOrder? @relation(fields: [groupOrderId], references: [id])

  @@index([customerId])
  @@map("order_analytics")
}

// Enums
enum GroupOrderStatus {
  ACTIVE
  LOCKED
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  ACTIVE
  REMOVED
}

enum OrderSource {
  DIRECT
  GROUP
  PARTNER
}

// ==========================================
// PRODUCTS & CATALOG
// ==========================================

model Product {
  id              String        @id @default(uuid())
  handle          String        @unique
  title           String
  description     String?       @db.Text
  descriptionHtml String?       @map("description_html") @db.Text
  vendor          String?
  productType     String?       @map("product_type")
  tags            String[]
  status          ProductStatus @default(ACTIVE)

  // Shopify sync fields (for parallel operation)
  shopifyId       String?   @unique @map("shopify_id")
  shopifySyncedAt DateTime? @map("shopify_synced_at")

  // Pricing (base - variants may override)
  basePrice      Decimal  @map("base_price") @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  currencyCode   String   @default("USD") @map("currency_code")

  // SEO
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  // Alcohol-specific metadata
  abv Decimal? @db.Decimal(4, 2) // Alcohol by volume

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  variants       ProductVariant[]
  images         ProductImage[]
  categories     ProductCategory[]
  inventoryItems InventoryItem[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([handle])
  @@index([productType])
  @@index([status])
  @@index([shopifyId])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  sku            String?  @unique
  title          String   @default("Default")
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)

  // Variant options (e.g., size: 750ml, 1L)
  option1Name  String? @map("option1_name")
  option1Value String? @map("option1_value")
  option2Name  String? @map("option2_name")
  option2Value String? @map("option2_value")
  option3Name  String? @map("option3_name")
  option3Value String? @map("option3_value")

  // Shopify sync
  shopifyId String? @unique @map("shopify_id")

  // Inventory tracking
  inventoryQuantity Int     @default(0) @map("inventory_quantity")
  trackInventory    Boolean @default(true) @map("track_inventory")
  allowBackorder    Boolean @default(false) @map("allow_backorder")

  // Status
  availableForSale Boolean @default(true) @map("available_for_sale")

  // Weight for shipping (grams)
  weight     Int?
  weightUnit String? @default("g") @map("weight_unit")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  image          ProductImage?   @relation(fields: [imageId], references: [id])
  imageId        String?         @map("image_id")
  inventoryItems InventoryItem[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([productId])
  @@index([sku])
  @@index([shopifyId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  url       String
  altText   String? @map("alt_text")
  width     Int?
  height    Int?
  position  Int     @default(0)

  // Shopify sync
  shopifyId String? @unique @map("shopify_id")

  createdAt DateTime @default(now()) @map("created_at")

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([productId])
  @@map("product_images")
}

model Category {
  id          String  @id @default(uuid())
  handle      String  @unique
  title       String
  description String?
  imageUrl    String? @map("image_url")
  parentId    String? @map("parent_id")
  position    Int     @default(0)

  // Shopify collection sync
  shopifyCollectionId String? @unique @map("shopify_collection_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryHierarchy")
  products ProductCategory[]

  @@index([handle])
  @@map("categories")
}

model ProductCategory {
  productId  String @map("product_id")
  categoryId String @map("category_id")
  position   Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// ==========================================
// INVENTORY MANAGEMENT
// ==========================================

model InventoryLocation {
  id        String  @id @default(uuid())
  name      String
  address   Json?
  isActive  Boolean @default(true) @map("is_active")
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inventoryItems InventoryItem[]
  aiCounts       AIInventoryCount[]

  @@map("inventory_locations")
}

model InventoryItem {
  id         String  @id @default(uuid())
  productId  String  @map("product_id")
  variantId  String? @map("variant_id")
  locationId String  @map("location_id")

  quantity          Int @default(0)
  reservedQuantity  Int @default(0) @map("reserved_quantity")
  lowStockThreshold Int @default(10) @map("low_stock_threshold")
  reorderPoint      Int @default(20) @map("reorder_point")
  reorderQuantity   Int @default(50) @map("reorder_quantity")

  // Cost tracking
  costPerUnit Decimal? @map("cost_per_unit") @db.Decimal(10, 2)

  lastCountedAt DateTime? @map("last_counted_at")
  lastCountedBy String?   @map("last_counted_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?     @relation(fields: [variantId], references: [id])
  location  InventoryLocation   @relation(fields: [locationId], references: [id])
  movements InventoryMovement[]

  @@unique([productId, variantId, locationId])
  @@index([locationId])
  @@index([productId])
  @@map("inventory_items")
}

model InventoryMovement {
  id               String                @id @default(uuid())
  inventoryItemId  String                @map("inventory_item_id")
  type             InventoryMovementType
  quantity         Int // Positive for additions, negative for removals
  previousQuantity Int                   @map("previous_quantity")
  newQuantity      Int                   @map("new_quantity")
  reason           String?
  referenceType    String?               @map("reference_type") // order, adjustment, ai_count, return
  referenceId      String?               @map("reference_id")

  // AI inventory count metadata
  aiConfidence Float?  @map("ai_confidence")
  aiImageUrl   String? @map("ai_image_url")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([createdAt])
  @@index([type])
  @@map("inventory_movements")
}

model LowStockAlert {
  id              String      @id @default(uuid())
  productId       String      @map("product_id")
  variantId       String?     @map("variant_id")
  locationId      String?     @map("location_id")
  currentQuantity Int         @map("current_quantity")
  threshold       Int
  status          AlertStatus @default(ACTIVE)
  acknowledgedAt  DateTime?   @map("acknowledged_at")
  acknowledgedBy  String?     @map("acknowledged_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([productId])
  @@map("low_stock_alerts")
}

enum InventoryMovementType {
  RECEIVED
  SOLD
  ADJUSTMENT
  RETURN
  TRANSFER
  AI_COUNT
  DAMAGED
  EXPIRED
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

// ==========================================
// CUSTOMERS
// ==========================================

model Customer {
  id               String  @id @default(uuid())
  email            String  @unique
  phone            String?
  firstName        String? @map("first_name")
  lastName         String? @map("last_name")
  acceptsMarketing Boolean @default(false) @map("accepts_marketing")

  // Shopify sync
  shopifyId String? @unique @map("shopify_id")

  // Stripe
  stripeCustomerId String? @unique @map("stripe_customer_id")

  // Authentication
  passwordHash     String?   @map("password_hash")
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")

  // Age verification (required for alcohol)
  ageVerified   Boolean   @default(false) @map("age_verified")
  ageVerifiedAt DateTime? @map("age_verified_at")
  dateOfBirth   DateTime? @map("date_of_birth")

  // Account status
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  addresses           CustomerAddress[]
  carts               Cart[]
  orders              Order[]
  groupOrdersHosted   GroupOrder[]       @relation("GroupOrderHost")
  groupParticipations GroupParticipant[] @relation("CustomerParticipations")
  loyalty             CustomerLoyalty?

  @@index([email])
  @@index([shopifyId])
  @@index([stripeCustomerId])
  @@map("customers")
}

model CustomerAddress {
  id         String  @id @default(uuid())
  customerId String  @map("customer_id")
  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  company    String?
  address1   String
  address2   String?
  city       String
  province   String  @default("TX")
  zip        String
  country    String  @default("US")
  phone      String?
  isDefault  Boolean @default(false) @map("is_default")

  // Shopify sync
  shopifyId String? @map("shopify_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

// ==========================================
// CART (SERVER-SIDE, PERSISTENT)
// ==========================================

model Cart {
  id         String     @id @default(uuid())
  customerId String?    @map("customer_id")
  sessionId  String?    @map("session_id") // For guest users
  status     CartStatus @default(ACTIVE)

  // Delivery info (stored in cart)
  deliveryDate         DateTime? @map("delivery_date")
  deliveryTime         String?   @map("delivery_time")
  deliveryAddress      Json?     @map("delivery_address")
  deliveryInstructions String?   @map("delivery_instructions") @db.Text
  deliveryPhone        String?   @map("delivery_phone")

  // Discount
  discountCode   String? @map("discount_code")
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)

  // Totals (computed, cached)
  subtotal    Decimal @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  deliveryFee Decimal @default(25) @map("delivery_fee") @db.Decimal(10, 2)
  total       Decimal @default(0) @db.Decimal(10, 2)

  // Group order association
  groupOrderId String? @map("group_order_id")

  // Cart expiration
  expiresAt         DateTime? @map("expires_at")
  abandonedAt       DateTime? @map("abandoned_at")
  recoveryEmailSent Boolean   @default(false) @map("recovery_email_sent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer   Customer?   @relation(fields: [customerId], references: [id])
  groupOrder GroupOrder? @relation(fields: [groupOrderId], references: [id])
  items      CartItem[]

  @@index([customerId])
  @@index([sessionId])
  @@index([status])
  @@index([groupOrderId])
  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  productId String  @map("product_id")
  variantId String  @map("variant_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Price at time of adding

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
  EXPIRED
}

// ==========================================
// ORDERS
// ==========================================

model Order {
  id          String @id @default(uuid())
  orderNumber Int    @unique @default(autoincrement()) @map("order_number")
  customerId  String @map("customer_id")

  // Status
  status            OrderStatus       @default(PENDING)
  financialStatus   FinancialStatus   @default(PENDING) @map("financial_status")
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED) @map("fulfillment_status")

  // Shopify sync (for orders created during transition)
  shopifyOrderId     String? @unique @map("shopify_order_id")
  shopifyOrderNumber String? @map("shopify_order_number")

  // Stripe
  stripePaymentIntentId   String? @unique @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripeChargeId          String? @map("stripe_charge_id")

  // Amounts
  subtotal       Decimal @db.Decimal(10, 2)
  discountCode   String? @map("discount_code")
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount      Decimal @map("tax_amount") @db.Decimal(10, 2)
  deliveryFee    Decimal @map("delivery_fee") @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  // Delivery
  deliveryDate         DateTime     @map("delivery_date")
  deliveryTime         String       @map("delivery_time")
  deliveryAddress      Json         @map("delivery_address")
  deliveryInstructions String?      @map("delivery_instructions") @db.Text
  deliveryPhone        String       @map("delivery_phone")
  deliveryType         DeliveryType @default(HOUSE) @map("delivery_type")

  // Customer info snapshot (in case customer changes later)
  customerEmail String  @map("customer_email")
  customerPhone String? @map("customer_phone")
  customerName  String  @map("customer_name")

  // Group order
  groupOrderId String? @map("group_order_id")

  // Notes
  customerNote String? @map("customer_note") @db.Text
  internalNote String? @map("internal_note") @db.Text

  // Cancellation
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id])
  groupOrder   GroupOrder?   @relation(fields: [groupOrderId], references: [id])
  items        OrderItem[]
  fulfillments Fulfillment[]
  refunds      Refund[]
  deliveryTask DeliveryTask?

  @@index([customerId])
  @@index([orderNumber])
  @@index([status])
  @@index([deliveryDate])
  @@index([shopifyOrderId])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  variantId String @map("variant_id")

  // Snapshot at time of order
  title        String
  variantTitle String? @map("variant_title")
  sku          String?
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  totalPrice   Decimal @map("total_price") @db.Decimal(10, 2)

  // Fulfillment tracking
  fulfilledQuantity Int @default(0) @map("fulfilled_quantity")
  refundedQuantity  Int @default(0) @map("refunded_quantity")

  createdAt DateTime @default(now()) @map("created_at")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Fulfillment {
  id              String            @id @default(uuid())
  orderId         String            @map("order_id")
  status          FulfillmentStatus @default(PENDING)
  trackingCompany String?           @map("tracking_company")
  trackingNumber  String?           @map("tracking_number")
  trackingUrl     String?           @map("tracking_url")

  // Driver assignment
  driverName  String? @map("driver_name")
  driverPhone String? @map("driver_phone")

  fulfilledAt DateTime? @map("fulfilled_at")
  deliveredAt DateTime? @map("delivered_at")

  // Proof of delivery
  deliveryPhoto     String? @map("delivery_photo")
  deliverySignature String? @map("delivery_signature")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("fulfillments")
}

model Refund {
  id             String       @id @default(uuid())
  orderId        String       @map("order_id")
  stripeRefundId String?      @unique @map("stripe_refund_id")
  amount         Decimal      @db.Decimal(10, 2)
  reason         String?
  status         RefundStatus @default(PENDING)

  // Who processed
  processedBy String? @map("processed_by")

  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("refunds")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOIDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum DeliveryType {
  HOUSE
  BOAT
  MARINA
}

// ==========================================
// AI INVENTORY FEATURES
// ==========================================

model AIInventoryCount {
  id         String        @id @default(uuid())
  locationId String        @map("location_id")
  imageUrl   String        @map("image_url")
  status     AICountStatus @default(PROCESSING)

  // Results
  rawResponse       Json?  @map("raw_response")
  detectedItems     Json?  @map("detected_items") // Array of {productId, quantity, confidence}
  overallConfidence Float? @map("overall_confidence")

  // Review
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedBy  String?   @map("reviewed_by")
  adjustments Json? // Manual adjustments made during review
  appliedAt   DateTime? @map("applied_at")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  location InventoryLocation @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([status])
  @@map("ai_inventory_counts")
}

model AIInventoryQuery {
  id         String  @id @default(uuid())
  query      String  @db.Text
  response   String  @db.Text
  tokensUsed Int?    @map("tokens_used")
  modelUsed  String? @map("model_used")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("ai_inventory_queries")
}

model InventoryPrediction {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  currentQuantity        Int       @map("current_quantity")
  averageDailySales      Float     @map("average_daily_sales")
  predictedStockoutDate  DateTime? @map("predicted_stockout_date")
  recommendedReorderDate DateTime? @map("recommended_reorder_date")
  recommendedQuantity    Int?      @map("recommended_quantity")

  confidenceScore Float? @map("confidence_score")
  factors         Json? // Factors considered in prediction

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([predictedStockoutDate])
  @@map("inventory_predictions")
}

enum AICountStatus {
  PROCESSING
  COMPLETED
  FAILED
  PENDING_REVIEW
  APPLIED
}

// ==========================================
// FEATURE FLAGS & SYNC
// ==========================================

model FeatureFlag {
  id          String  @id @default(uuid())
  key         String  @unique
  enabled     Boolean @default(false)
  description String?

  // Rollout percentage (0-100)
  rolloutPercentage Int @default(0) @map("rollout_percentage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model ShopifySync {
  id           String        @id @default(uuid())
  entityType   String        @map("entity_type") // product, customer, order
  entityId     String        @map("entity_id")
  shopifyId    String        @map("shopify_id")
  direction    SyncDirection
  status       SyncStatus    @default(PENDING)
  errorMessage String?       @map("error_message")

  syncedAt  DateTime? @map("synced_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([shopifyId])
  @@index([status])
  @@map("shopify_syncs")
}

enum SyncDirection {
  SHOPIFY_TO_LOCAL
  LOCAL_TO_SHOPIFY
  BIDIRECTIONAL
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ==========================================
// DELIVERY TASKS & EMAIL LOGS
// ==========================================

model DeliveryTask {
  id      String             @id @default(uuid())
  orderId String             @unique @map("order_id")
  status  DeliveryTaskStatus @default(PENDING)

  // Scheduled delivery
  scheduledDate DateTime  @map("scheduled_date")
  scheduledTime String    @map("scheduled_time")

  // Driver assignment
  driverName  String? @map("driver_name")
  driverPhone String? @map("driver_phone")
  driverNotes String? @map("driver_notes") @db.Text

  // Delivery tracking
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  failedAt    DateTime? @map("failed_at")
  failReason  String?   @map("fail_reason")

  // Delivery proof
  deliveryPhoto     String? @map("delivery_photo")
  deliverySignature String? @map("delivery_signature")
  recipientName     String? @map("recipient_name")

  // Customer notification tracking
  notifiedEnRoute   Boolean   @default(false) @map("notified_en_route")
  notifiedDelivered Boolean   @default(false) @map("notified_delivered")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([scheduledDate])
  @@map("delivery_tasks")
}

model EmailLog {
  id        String      @id @default(uuid())
  type      EmailType
  to        String
  subject   String
  status    EmailStatus @default(PENDING)

  // Reference to related entity
  orderId    String? @map("order_id")
  customerId String? @map("customer_id")

  // Resend tracking
  resendId      String?   @map("resend_id")
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  openedAt      DateTime? @map("opened_at")
  errorMessage  String?   @map("error_message")

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([orderId])
  @@index([status])
  @@map("email_logs")
}

enum DeliveryTaskStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  DELIVERED
  FAILED
  CANCELLED
}

enum EmailType {
  ORDER_CONFIRMATION
  DELIVERY_SCHEDULED
  DELIVERY_EN_ROUTE
  DELIVERY_COMPLETED
  PAYMENT_FAILED
  REFUND_PROCESSED
  WELCOME
  PASSWORD_RESET
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  FAILED
}

// ==========================================
// DISCOUNTS & PROMOTIONS
// ==========================================

model Discount {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  description String?
  type        DiscountType

  // Value (percentage or fixed amount)
  value Decimal @db.Decimal(10, 2)

  // Applicability
  appliesToAll         Boolean  @default(true) @map("applies_to_all")
  applicableProducts   String[] @map("applicable_products")
  applicableCategories String[] @map("applicable_categories")

  // Conditions
  minOrderAmount   Decimal? @map("min_order_amount") @db.Decimal(10, 2)
  minQuantity      Int?     @map("min_quantity")
  maxUsageCount    Int?     @map("max_usage_count")
  usagePerCustomer Int?     @map("usage_per_customer")

  // Buy X Get Y specific fields
  buyQuantity Int? @map("buy_quantity")
  getQuantity Int? @map("get_quantity")

  // Validity
  startsAt  DateTime  @default(now()) @map("starts_at")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")

  // Tracking
  usageCount         Int     @default(0) @map("usage_count")
  totalDiscountGiven Decimal @default(0) @map("total_discount_given") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usageHistory DiscountUsage[]

  @@index([code])
  @@index([isActive])
  @@map("discounts")
}

model DiscountUsage {
  id          String   @id @default(uuid())
  discountId  String   @map("discount_id")
  customerId  String?  @map("customer_id")
  orderId     String   @map("order_id")
  amountSaved Decimal  @map("amount_saved") @db.Decimal(10, 2)
  usedAt      DateTime @default(now()) @map("used_at")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@index([discountId])
  @@index([customerId])
  @@index([orderId])
  @@map("discount_usages")
}

model ReferralCode {
  id             String  @id @default(uuid())
  code           String  @unique
  referrerId     String  @map("referrer_id")
  discountId     String  @map("discount_id")
  referrerReward Decimal @map("referrer_reward") @db.Decimal(10, 2)

  usageCount     Int @default(0) @map("usage_count")
  totalReferrals Int @default(0) @map("total_referrals")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([code])
  @@index([referrerId])
  @@map("referral_codes")
}

model AutomaticDiscount {
  id    String       @id @default(uuid())
  name  String
  type  DiscountType
  value Decimal      @db.Decimal(10, 2)

  // Trigger conditions
  triggerType  AutoDiscountTrigger @map("trigger_type")
  triggerValue Decimal?            @map("trigger_value") @db.Decimal(10, 2)

  // Applicability
  appliesToAll       Boolean  @default(true) @map("applies_to_all")
  applicableProducts String[] @map("applicable_products")

  // Priority and stacking
  priority  Int     @default(0)
  stackable Boolean @default(false)

  // Validity
  startsAt  DateTime  @default(now()) @map("starts_at")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([triggerType])
  @@map("automatic_discounts")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
  FREE_SHIPPING
}

enum AutoDiscountTrigger {
  CART_TOTAL
  PRODUCT_COUNT
  FIRST_ORDER
  SPECIFIC_PRODUCT
}

// ==========================================
// LOYALTY PROGRAM
// ==========================================

model LoyaltyTier {
  id               String  @id @default(uuid())
  name             String  @unique
  minLifetimeSpend Decimal @map("min_lifetime_spend") @db.Decimal(10, 2)
  pointsMultiplier Float   @default(1) @map("points_multiplier")
  discountPercent  Int     @default(0) @map("discount_percent")
  freeDeliveryMin  Decimal? @map("free_delivery_min") @db.Decimal(10, 2)
  benefits         String[]
  color            String   @default("#6B7280")
  position         Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customerLoyalty CustomerLoyalty[]

  @@map("loyalty_tiers")
}

model CustomerLoyalty {
  id            String  @id @default(uuid())
  customerId    String  @unique @map("customer_id")
  tierId        String  @map("tier_id")
  points        Int     @default(0)
  lifetimeSpend Decimal @default(0) @map("lifetime_spend") @db.Decimal(10, 2)
  lifetimePoints Int    @default(0) @map("lifetime_points")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer     Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier         LoyaltyTier         @relation(fields: [tierId], references: [id])
  transactions PointsTransaction[]

  @@index([customerId])
  @@index([tierId])
  @@map("customer_loyalty")
}

model PointsTransaction {
  id          String     @id @default(uuid())
  loyaltyId   String     @map("loyalty_id")
  type        PointsType
  points      Int
  orderId     String?    @map("order_id")
  description String?

  createdAt DateTime @default(now()) @map("created_at")

  loyalty CustomerLoyalty @relation(fields: [loyaltyId], references: [id], onDelete: Cascade)

  @@index([loyaltyId])
  @@index([orderId])
  @@map("points_transactions")
}

enum PointsType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
  BONUS
}
