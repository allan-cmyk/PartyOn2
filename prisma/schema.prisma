// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Partner Inquiries from the partner pages
model PartnerInquiry {
  id               String   @id @default(uuid())
  businessName     String   @map("business_name")
  businessType     String?  @map("business_type")
  contactName      String   @map("contact_name")
  email            String
  phone            String?
  numberOfRooms    String?  @map("number_of_rooms")
  monthlyVolume    String?  @map("monthly_volume")
  currentProvider  String?  @map("current_provider")
  interests        String[]
  message          String?
  status           String   @default("new")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("partner_inquiries")
}

// Group Orders - for group ordering feature
model GroupOrder {
  id                  String              @id @default(uuid())
  name                String
  hostCustomerId      String              @map("host_customer_id")
  hostName            String?             @map("host_name")
  shareCode           String              @unique @map("share_code")
  status              GroupOrderStatus    @default(ACTIVE)
  deliveryDate        DateTime            @map("delivery_date")
  deliveryTime        String              @map("delivery_time")
  deliveryAddress     Json                @map("delivery_address")
  minimumOrderAmount  Decimal             @default(100.00) @map("minimum_order_amount")
  expiresAt           DateTime            @map("expires_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  
  participants        GroupParticipant[]
  items               GroupOrderItem[]
  orderAnalytics      OrderAnalytics[]

  @@index([shareCode])
  @@index([hostCustomerId])
  @@map("group_orders")
}

// Participants in group orders
model GroupParticipant {
  id               String            @id @default(uuid())
  groupOrderId     String            @map("group_order_id")
  customerId       String?           @map("customer_id")
  guestName        String?           @map("guest_name")
  guestEmail       String?           @map("guest_email")
  cartId           String            @map("cart_id")
  ageVerified      Boolean           @default(false) @map("age_verified")
  status           ParticipantStatus @default(ACTIVE)
  cartTotal        Decimal           @default(0) @map("cart_total")
  itemCount        Int               @default(0) @map("item_count")
  joinedAt         DateTime          @default(now()) @map("joined_at")
  // Checkout tracking fields (new)
  checkedOutAt     DateTime?         @map("checked_out_at")
  shopifyOrderId   String?           @map("shopify_order_id")
  shopifyOrderName String?           @map("shopify_order_name")

  groupOrder       GroupOrder        @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)

  @@unique([groupOrderId, cartId])
  @@index([groupOrderId])
  @@index([cartId])
  @@index([status])
  @@map("group_participants")
}

// Items purchased in group orders (for visibility to all participants)
model GroupOrderItem {
  id              String     @id @default(uuid())
  groupOrderId    String     @map("group_order_id")
  participantId   String     @map("participant_id")
  shopifyLineId   String     @map("shopify_line_id")
  title           String
  variantTitle    String?    @map("variant_title")
  quantity        Int
  price           Decimal
  imageUrl        String?    @map("image_url")
  createdAt       DateTime   @default(now()) @map("created_at")

  groupOrder      GroupOrder @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)

  @@index([groupOrderId])
  @@map("group_order_items")
}

// Order Analytics - supplementary data for Shopify orders
model OrderAnalytics {
  id              String      @id @default(uuid())
  shopifyOrderId  String?     @unique @map("shopify_order_id")
  customerId      String      @map("customer_id")
  orderTotal      Decimal     @map("order_total")
  deliveryDate    DateTime?   @map("delivery_date")
  deliveryTime    String?     @map("delivery_time")
  deliveryAddress Json?       @map("delivery_address")
  orderSource     OrderSource @map("order_source")
  partnerId       String?     @map("partner_id")
  groupOrderId    String?     @map("group_order_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  
  groupOrder      GroupOrder? @relation(fields: [groupOrderId], references: [id])

  @@index([customerId])
  @@map("order_analytics")
}

// Enums
enum GroupOrderStatus {
  ACTIVE
  LOCKED      // Legacy - kept for backwards compatibility
  CLOSED      // New - prevents new joins but doesn't trigger checkout
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  ACTIVE
  REMOVED
  CHECKED_OUT // New - participant has completed their individual checkout
}

enum OrderSource {
  DIRECT
  GROUP
  PARTNER
}

// Daily Analytics Snapshots - historical tracking
model AnalyticsSnapshot {
  id                  String   @id @default(uuid())
  date                DateTime @unique @db.Date

  // Traffic metrics (from GA4 when configured)
  sessions            Int      @default(0)
  users               Int      @default(0)
  pageviews           Int      @default(0)
  bounceRate          Decimal? @map("bounce_rate")
  avgSessionDuration  Decimal? @map("avg_session_duration")

  // Traffic sources
  organicSessions     Int      @default(0) @map("organic_sessions")
  directSessions      Int      @default(0) @map("direct_sessions")
  referralSessions    Int      @default(0) @map("referral_sessions")
  socialSessions      Int      @default(0) @map("social_sessions")
  paidSessions        Int      @default(0) @map("paid_sessions")

  // Sales metrics (from Shopify)
  orders              Int      @default(0)
  revenue             Decimal  @default(0)
  averageOrderValue   Decimal  @default(0) @map("average_order_value")

  // SEO metrics (from Search Console when configured)
  impressions         Int      @default(0)
  clicks              Int      @default(0)
  ctr                 Decimal? @default(0)
  avgPosition         Decimal? @map("avg_position")

  // Top data (JSON for flexibility)
  topPages            Json?    @map("top_pages")
  topProducts         Json?    @map("top_products")
  topKeywords         Json?    @map("top_keywords")
  topReferrers        Json?    @map("top_referrers")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@map("analytics_snapshots")
}

// A/B Testing Experiments
model Experiment {
  id             String           @id @default(cuid())
  name           String
  description    String?
  page           String           // e.g., "/", "/weddings", "/order"
  elementId      String           @map("element_id") // e.g., "hero", "cta-primary"
  status         ExperimentStatus @default(DRAFT)
  startDate      DateTime?        @map("start_date")
  endDate        DateTime?        @map("end_date")
  goalMetric     String           @map("goal_metric") // "cta_click", "scroll_depth", "conversion"
  goalValue      String?          @map("goal_value") // specific value to track
  winningVariant String?          @map("winning_variant")
  confidence     Float?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  variants       Variant[]

  @@index([page])
  @@index([status])
  @@map("experiments")
}

// A/B Test Variants
model Variant {
  id           String     @id @default(cuid())
  experimentId String     @map("experiment_id")
  name         String     // "Control", "Variant A", "Variant B"
  description  String?
  isControl    Boolean    @default(false) @map("is_control")
  weight       Int        @default(50) // traffic percentage
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  conversions  Int        @default(0)
  revenue      Float      @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@map("variants")
}

enum ExperimentStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}