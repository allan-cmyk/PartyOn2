// ==========================================
// DRAFT ORDERS (INVOICING SYSTEM)
// ==========================================

model DraftOrder {
  id     String           @id @default(uuid())
  token  String           @unique @default(uuid()) // For secure payment link
  status DraftOrderStatus @default(PENDING)

  // Customer info
  customerEmail String  @map("customer_email")
  customerName  String  @map("customer_name")
  customerPhone String? @map("customer_phone")

  // Delivery info (pre-filled, customer doesn't enter)
  deliveryAddress String   @map("delivery_address")
  deliveryCity    String   @map("delivery_city")
  deliveryState   String   @default("TX") @map("delivery_state")
  deliveryZip     String   @map("delivery_zip")
  deliveryDate    DateTime @map("delivery_date")
  deliveryTime    String   @map("delivery_time")
  deliveryNotes   String?  @map("delivery_notes") @db.Text

  // Order details - JSON array of items
  // Each item: {productId, variantId, title, variantTitle, quantity, price, imageUrl?}
  items Json

  // Amounts
  subtotal       Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @map("tax_amount") @db.Decimal(10, 2)
  deliveryFee    Decimal @map("delivery_fee") @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountCode   String? @map("discount_code")
  total          Decimal @db.Decimal(10, 2)

  // Payment tracking
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?   @unique @map("stripe_payment_intent_id")
  paidAt                  DateTime? @map("paid_at")

  // Lifecycle
  sentAt           DateTime? @map("sent_at") // When invoice email sent
  viewedAt         DateTime? @map("viewed_at") // When customer opened link
  expiresAt        DateTime? @map("expires_at") // Optional expiration
  convertedOrderId String?   @map("converted_order_id") // If converted to real order

  // Admin
  createdBy  String? @map("created_by") // Admin who created
  adminNotes String? @map("admin_notes") @db.Text

  // Group order association (optional)
  groupOrderId String? @map("group_order_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerEmail])
  @@index([status])
  @@index([createdAt])
  @@index([groupOrderId])
  @@map("draft_orders")
}

enum DraftOrderStatus {
  PENDING // Created, not sent
  SENT // Invoice emailed to customer
  VIEWED // Customer opened the link
  PAID // Payment completed
  CONVERTED // Converted to Order
  EXPIRED // Link expired
  CANCELLED // Manually cancelled
}

